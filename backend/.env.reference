# =============================================================================
# .env.reference — complete documentation for every environment variable
#
# This file is NOT loaded by the application. It is a human-readable reference.
# Copy values you want to change into your .env file.
#
# For a ready-to-run local setup, start from the LOCAL MODE block in
# .env.template, then consult this file for tuning options.
# =============================================================================


# =============================================================================
# PROVIDER SELECTION
# These eight vars control which backend is used for each subsystem.
# Invalid values fall back to the cloud default silently.
# =============================================================================

LLM_PROVIDER=openai
# Options:
#   openai   — OpenAI API (requires OPENAI_API_KEY)
#   ollama   — local Ollama server (requires OLLAMA_HOST)

STT_PROVIDER=deepgram
# Options:
#   deepgram — Deepgram cloud ASR (requires DEEPGRAM_API_KEY)
#   local    — faster-whisper running on this machine (zero cloud deps)

EMBEDDINGS_PROVIDER=openai
# Options:
#   openai   — OpenAI text-embedding-3-large (requires OPENAI_API_KEY)
#   local    — sentence-transformers model on this machine (zero cloud deps)

VECTOR_DB_PROVIDER=pinecone
# Options:
#   pinecone — Pinecone cloud vector DB (requires PINECONE_API_KEY)
#   qdrant   — Qdrant running locally in Docker (zero cloud deps)

AUTH_PROVIDER=firebase
# Options:
#   firebase — Firebase Auth (requires GOOGLE_APPLICATION_CREDENTIALS)
#   local    — local JWT (PBKDF2 password hashing + HS256 tokens, zero cloud deps)

DB_PROVIDER=firestore
# Options:
#   firestore — Google Cloud Firestore (requires GOOGLE_APPLICATION_CREDENTIALS)
#   sqlite    — SQLite file on disk (zero cloud deps, single-process only)
#   postgres  — PostgreSQL (requires SQL_URL)

EVENT_PROVIDER=pusher
# Options:
#   pusher    — Pusher cloud (requires HOSTED_PUSHER_API_URL)
#   websocket — in-process FastAPI WebSocket broadcast (zero cloud deps)

SEARCH_PROVIDER=typesense
# Options:
#   typesense — Typesense cloud/self-hosted full-text search (requires TYPESENSE_* vars)
#   local     — SQLite FTS5 full-text search (zero cloud deps)
#   disabled  — search endpoints return 501; suppresses "typesense not installed" errors

ENABLE_DIARIZATION=true
# Options:
#   true  — enable speaker diarization (requires a diarizer service)
#   false — skip diarization (required in local mode; no diarizer service running)


# =============================================================================
# OLLAMA  (used when LLM_PROVIDER=ollama)
# =============================================================================

OLLAMA_HOST=http://localhost:11434
# Any reachable URL. Examples:
#   http://localhost:11434         local Ollama app (default)
#   http://192.168.1.50:11434      Ollama on another machine on your LAN
#   http://ollama.internal:11434   Docker/k8s service name

OLLAMA_MODEL=qwen3:0.6b
# Default model used when no purpose-specific override is set.
# Any model name visible in `ollama list`. Common choices:
#   qwen3:0.6b    — tiny (~500 MB), fast, good for extraction
#   qwen3:4b      — small, good balance
#   llama3.1      — 8B, solid general purpose (~4.7 GB)
#   llama3.1:70b  — large, best quality (requires ~40 GB RAM)
#   mistral       — 7B, fast and capable
#   gemma3:4b     — Google, strong reasoning

OLLAMA_CHAT_MODEL=
# Override model for conversational chat and streaming only.
# Falls back to OLLAMA_MODEL when not set.
# Use a larger/more capable model here for better conversation quality.

OLLAMA_EXTRACT_MODEL=
# Override model for generate() and action-item extraction only.
# Falls back to OLLAMA_MODEL when not set.
# A smaller/faster model is fine here (structured JSON output, short prompts).

OLLAMA_TIMEOUT=300
# Seconds to wait for a single Ollama HTTP response before giving up.
# 300 is a safe default; reduce to 60–120 for small models on fast hardware.


# =============================================================================
# LOCAL STT — faster-whisper  (used when STT_PROVIDER=local)
# =============================================================================

LOCAL_WHISPER_MODEL=base
# Whisper model size. Larger = more accurate, slower, more RAM.
#   tiny      — ~75 MB,   ~32x realtime on CPU,  rough accuracy
#   base      — ~141 MB,  ~16x realtime on CPU,  good for clear speech  ← default
#   small     — ~461 MB,  ~6x  realtime on CPU,  good accuracy
#   medium    — ~1.5 GB,  ~2x  realtime on CPU,  high accuracy
#   large-v2  — ~3 GB,    ~1x  realtime on CPU,  very high accuracy
#   large-v3  — ~3 GB,    ~1x  realtime on CPU,  best accuracy (recommended if RAM allows)
# Models are downloaded automatically on first use to ~/.cache/huggingface/hub/

LOCAL_WHISPER_DEVICE=cpu
# Options:
#   cpu   — works everywhere, no GPU required
#   cuda  — NVIDIA GPU (significant speedup; requires torch+cuda installed)
#   mps   — Apple Silicon GPU via Metal (meaningful speedup on M-series Macs)
# Note: if CUDA/MPS is unavailable, faster-whisper silently falls back to CPU.

LOCAL_WHISPER_COMPUTE_TYPE=int8
# Quantisation level. Lower precision = faster + less RAM, minor accuracy loss.
#   int8      — fastest, least RAM, works on CPU and GPU  ← recommended default
#   float16   — half precision; GPU only (cuda/mps); better accuracy than int8
#   float32   — full precision; highest accuracy, highest RAM usage
# int8 is a good default for all device types. Use float16 on GPU for production.


# =============================================================================
# LOCAL STREAMING STT  (used when STT_PROVIDER=local)
# These control how the transcribe WebSocket chops the incoming PCM stream.
# You should not need to change these unless you are feeding non-standard audio.
# =============================================================================

LOCAL_STREAM_CHUNK_SECONDS=5
# How many seconds of PCM to accumulate before passing to Whisper.
# Smaller = lower latency but more Whisper invocations. Minimum: ~1.

LOCAL_STREAM_SAMPLE_RATE=16000
# Expected sample rate of incoming PCM16 audio. Must match what the client sends.
# The Omi pin and pin_bridge.py both output 16000 Hz.

LOCAL_STREAM_BYTES_PER_SAMPLE=2
# 2 = PCM16 (16-bit signed, the only format Whisper accepts natively).

LOCAL_STREAM_CHANNELS=1
# 1 = mono. The Omi pin is mono; do not change unless you have a custom client.


# =============================================================================
# LOCAL VAD  (used when STT_PROVIDER=local)
# Voice Activity Detection filters silence before sending audio to Whisper.
# =============================================================================

LOCAL_VAD_BACKEND=energy
# Options:
#   energy  — fast RMS energy heuristic, zero extra dependencies  ← default
#   silero  — Silero VAD neural model (more accurate, requires torch + silero-vad)
#             If silero fails to load it falls back to energy automatically.

LOCAL_VAD_RMS_THRESHOLD=300
# Only used when LOCAL_VAD_BACKEND=energy.
# RMS amplitude below this value is classified as silence.
# Increase in noisy environments (400–600); decrease for quiet microphones (100–200).

LOCAL_VAD_SILERO_THRESHOLD=0.5
# Only used when LOCAL_VAD_BACKEND=silero.
# Probability threshold above which a frame is classified as speech (0.0–1.0).
# Lower = more sensitive (captures quiet speech but more false positives).

LOCAL_VAD_SAMPLE_RATE=16000
# Sample rate fed to the Silero model. Should match LOCAL_STREAM_SAMPLE_RATE.

VAD_GATE_MODE=off
# Controls whether VAD gating suppresses silence on the wire.
# Options:
#   off    — VAD disabled entirely; all audio forwarded to Whisper  ← default
#   shadow — VAD runs and logs its decisions but does not suppress any audio
#   active — VAD gates: silence is dropped; a KeepAlive packet is sent instead


# =============================================================================
# LOCAL EMBEDDINGS  (used when EMBEDDINGS_PROVIDER=local)
# =============================================================================

LOCAL_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Any sentence-transformers model name from HuggingFace Hub. Common choices:
#   sentence-transformers/all-MiniLM-L6-v2     — 384-dim, ~80 MB, fast  ← default
#   sentence-transformers/all-mpnet-base-v2    — 768-dim, ~420 MB, better quality
#   sentence-transformers/all-MiniLM-L12-v2   — 384-dim, ~120 MB, slightly better than L6
#   BAAI/bge-small-en-v1.5                     — 384-dim, ~130 MB, strong retrieval quality
# Models download automatically on first use to ~/.cache/huggingface/hub/

LOCAL_EMBEDDINGS_DIM=384
# MUST match the output dimension of LOCAL_EMBEDDINGS_MODEL exactly.
# Mismatch causes silent wrong results or Qdrant collection errors.
# Dimensions for common models:
#   all-MiniLM-L6-v2    → 384
#   all-MiniLM-L12-v2   → 384
#   bge-small-en-v1.5   → 384
#   all-mpnet-base-v2   → 768
#   bge-large-en-v1.5   → 1024


# =============================================================================
# VECTOR DB — Qdrant  (used when VECTOR_DB_PROVIDER=qdrant)
# =============================================================================

QDRANT_URL=http://localhost:6333
# URL of the Qdrant REST API. Examples:
#   http://localhost:6333       local Docker container (default)
#   http://192.168.1.50:6333    Qdrant on another LAN host
#   https://xyz.qdrant.io       Qdrant Cloud (add QDRANT_API_KEY)

QDRANT_API_KEY=
# Required for Qdrant Cloud; leave empty for local Docker.


# =============================================================================
# DATABASE — SQLite  (used when DB_PROVIDER=sqlite)
# =============================================================================

SQLITE_PATH=./omi_local.db
# Path to the SQLite database file, relative to the backend directory.
# Use an absolute path to pin the location regardless of working directory.

SQL_URL=
# Full SQLAlchemy URL. Overrides SQLITE_PATH when set. Examples:
#   sqlite:///./omi_local.db              same as SQLITE_PATH default
#   postgresql://user:pass@host/dbname    PostgreSQL (set DB_PROVIDER=postgres)
# Leave empty to let the code derive it from SQLITE_PATH.


# =============================================================================
# AUTH — local JWT  (used when AUTH_PROVIDER=local)
# =============================================================================

LOCAL_JWT_SECRET=change-me-in-production
# Secret key used to sign and verify JWT tokens (HMAC-SHA256).
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: changing this invalidates all existing tokens (all users log out).

LOCAL_JWT_TTL_SECONDS=86400
# How long an issued token is valid. Default: 86400 = 24 hours.
# Examples: 3600 (1 h), 604800 (7 days), 2592000 (30 days).

LOCAL_JWT_ALGORITHM=HS256
# JWT signing algorithm. HS256 is the only tested option; do not change.

BOOTSTRAP_ADMIN_EMAIL=
# If set, an admin user with this email is created on first boot (if missing).
# Leave empty to skip bootstrapping.

BOOTSTRAP_ADMIN_PASSWORD=
# Password for the bootstrapped admin user. Required if BOOTSTRAP_ADMIN_EMAIL is set.

LOCAL_AUTH_BYPASS=
# Options: true | false (default: unset = false)
# When true, the backend accepts any non-empty Bearer token without verifying
# its JWT signature. The user ID is derived from the token payload directly.
# USE CASE: iOS app users sign in via Firebase; the resulting Firebase ID token
# is accepted by the local backend without a Firebase network call.
# SECURITY: only enable on a trusted private network. Any token is accepted.
# Leave unset (or false) when using Desktop app or pin_bridge exclusively.


# =============================================================================
# LOCAL SERVER
# =============================================================================

LOCAL_MACHINE_HOST=localhost
# LAN IP or hostname of the machine running this backend.
# Used by setup-clients.sh and sync-local-ip.sh to populate API_BASE_URL in
# the Flutter app and desktop .env files.
# Examples:
#   localhost       — all clients on the same machine (default)
#   192.168.1.50    — backend on one Mac, clients on other devices on the LAN
# Does not affect which interface uvicorn binds to (see --host in start_local.sh).

DOCS_API_KEY=
# When set, Swagger UI (/docs), ReDoc (/redoc), and OpenAPI schema (/openapi.json)
# require this key as a query parameter: http://localhost:8088/docs?key=<value>
# Leave empty to keep the API docs publicly accessible (fine on a trusted LAN).


# =============================================================================
# REDIS  (optional — backend operates without Redis but some features degrade)
# =============================================================================

REDIS_DB_HOST=
# Hostname or IP of the Redis server. Leave empty to run without Redis.
# Without Redis: rate limiting, fair-use tracking, and pub/sub are disabled (fail-open).

REDIS_DB_PORT=6379
# Redis port. Default: 6379.

REDIS_DB_PASSWORD=
# Redis AUTH password. Leave empty for no-auth Redis (typical in local dev).

TRANSLATION_CACHE_TTL=1209600
# Seconds to cache translated strings in Redis. Default: 1209600 = 14 days.
# Only relevant when Redis is connected and translation is in use.


# =============================================================================
# RATE LIMITING  (used when Redis is connected)
# =============================================================================

RATE_LIMIT_BOOST=1.0
# Float multiplier applied to all rate limit thresholds.
# 1.0 = default limits. 2.0 = double the limits. 0.5 = half.
# Useful for load testing or giving extra headroom to specific deployments.

RATE_LIMIT_SHADOW_MODE=false
# Options:
#   false — enforce limits; requests over the limit receive HTTP 429  ← default
#   true  — shadow mode; limits are logged but never enforced (no 429 returned)
# Useful when tuning limits without breaking clients.


# =============================================================================
# AUTO-PERSIST TRANSCRIPTS  (local mode only)
# =============================================================================

AUTO_PERSIST_TRANSCRIPTS=false
# Options:
#   false — transcripts are streamed back to the WebSocket client only; nothing is saved
#   true  — each completed transcript is automatically saved as a Conversation row in SQLite
# Requires DB_PROVIDER=sqlite (or postgres). Enabled automatically by main_local.py.


# =============================================================================
# macOS COMPATIBILITY
# =============================================================================

KMP_DUPLICATE_LIB_OK=TRUE
# Required on macOS when both PyTorch and ctranslate2 (faster-whisper) are
# installed. Both bundle their own OpenMP runtime (libiomp5.dylib), which
# causes an "Abort trap: 6" on startup without this flag.
# Safe to set unconditionally; has no effect on Linux.


# =============================================================================
# OPENAI  (used when LLM_PROVIDER=openai or EMBEDDINGS_PROVIDER=openai)
# =============================================================================

OPENAI_API_KEY=
# Your OpenAI API key (sk-...). Required for cloud LLM and embeddings.

OPENAI_EMBEDDINGS_DIM=3072
# Output dimension of the OpenAI embedding model. Default matches
# text-embedding-3-large. Do not change unless you switch embedding models.


# =============================================================================
# DEEPGRAM  (used when STT_PROVIDER=deepgram)
# =============================================================================

DEEPGRAM_API_KEY=
# Your Deepgram API key. Required for cloud speech-to-text.


# =============================================================================
# TYPESENSE  (used when SEARCH_PROVIDER=typesense)
# =============================================================================

TYPESENSE_HOST=
# Hostname of the Typesense server (no protocol, no port). Example: search.example.com

TYPESENSE_HOST_PORT=443
# Port number. Typically 443 for cloud, 8108 for self-hosted HTTP.

TYPESENSE_API_KEY=
# Typesense API key with read access to the conversations collection.


# =============================================================================
# FIREBASE / GOOGLE  (used when AUTH_PROVIDER=firebase or DB_PROVIDER=firestore)
# =============================================================================

GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json
# Path to the Google service account JSON key file.
# Relative paths are resolved from the backend directory.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
# Firebase project credentials for OAuth flows.


# =============================================================================
# PUSHER / EVENTS  (used when EVENT_PROVIDER=pusher)
# =============================================================================

HOSTED_PUSHER_API_URL=
# Internal URL of your pusher sub-service. Required for cloud event delivery.
# Without this, conversations stay in_progress permanently in cloud mode.


# =============================================================================
# PINECONE  (used when VECTOR_DB_PROVIDER=pinecone)
# =============================================================================

PINECONE_API_KEY=
PINECONE_INDEX_NAME=


# =============================================================================
# LANGSMITH  (optional LLM observability — cloud mode only)
# =============================================================================

LANGSMITH_TRACING=false
# Options: true | false. Enables LangSmith trace logging.

LANGSMITH_API_KEY=
# Your LangSmith API key. Required when LANGSMITH_TRACING=true.

LANGSMITH_PROJECT=omi-backend-chat
# LangSmith project name traces are grouped under.

LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LangSmith API endpoint. Only change if using a self-hosted LangSmith instance.

OMI_LANGSMITH_AGENTIC_PROMPT_NAME=omi-agentic-system
# Name of the prompt in LangSmith Hub used for the agentic chat system.
# Defaults to "omi-agentic-system" when not set.

OMI_LANGSMITH_PROMPT_CACHE_TTL_SECONDS=300
# How long the fetched LangSmith prompt is cached locally (seconds).
# Lower = faster prompt updates; higher = fewer API calls. Default: 300 (5 min).


# =============================================================================
# ADMIN / METRICS
# =============================================================================

ADMIN_KEY=
# When set, requests with the header `Authorization: Bearer ADMIN_KEY<uid>`
# bypass Firebase auth in cloud mode. Useful for local dev against main.py.
# Leave empty in production.

METRICS_SECRET=
# Bearer token required to access the /metrics endpoint.
# Leave empty to disable metrics authentication (not recommended in production).


# =============================================================================
# ENCRYPTION
# =============================================================================

ENCRYPTION_SECRET=omi_ZwB2ZNqB2HHpMK6wStk7sTpavJiPTFg7gXUHnc4tFABPU6pZ2c2DKgehtfgi4RZv
# AES-256-GCM key (base64-encoded) used to encrypt conversations, memories,
# and chat messages at rest. The default value is for development only.
# Generate a production secret: python -c "import secrets,base64; print('omi_'+base64.urlsafe_b64encode(secrets.token_bytes(48)).decode())"
# IMPORTANT: changing this makes all existing encrypted data unreadable.


# =============================================================================
# STORAGE BUCKETS  (cloud mode only)
# =============================================================================

BUCKET_SPEECH_PROFILES=
BUCKET_BACKUPS=
BUCKET_PLUGINS_LOGOS=
# Google Cloud Storage bucket names. Not used in local mode.


# =============================================================================
# THIRD-PARTY INTEGRATIONS  (cloud mode only — not needed for local setup)
# =============================================================================

ELEVENLABS_API_KEY=
# ElevenLabs TTS key. Used by /v2/tts/synthesize (returns 501 in local mode).

HUGGINGFACE_TOKEN=
# HuggingFace API token. Only required for gated models. Public models
# (Whisper, sentence-transformers) download without a token.

PERPLEXITY_API_KEY=
# Perplexity API for web-search tool in the agentic chat retrieval pipeline.

STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
# Stripe payment processing. The payment router is disabled when STRIPE_API_KEY is empty.

RAPID_API_HOST=
RAPID_API_KEY=

HUME_API_KEY=
HUME_CALLBACK_URL=

# Google OAuth (Calendar / Drive integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Twitter OAuth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Whoop integration
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Notion integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Twilio (phone calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=

GITHUB_TOKEN=

BASE_API_URL=
API_BASE_URL=
