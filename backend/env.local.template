# ── LOCAL ONLY — this file has no upstream equivalent ──
# env.local.template — local-mode variables for the Omi local backend.
#
# Usage: combine with .env.template to build your .env file:
#   cp .env.template .env
#   cat env.local.template >> .env
#   # Then edit .env and fill in real values (JWT secret, admin password, etc.)
#
# Requires: Ollama running + Qdrant in Docker (see SETUP_FROM_SCRATCH.md)
# =====================================================================

# ──── LOCAL PROVIDER SELECTION ───────────────────────────────────────
# These override the upstream cloud defaults in .env.template.
STT_PROVIDER=local
LLM_PROVIDER=ollama
EMBEDDINGS_PROVIDER=local
VECTOR_DB_PROVIDER=qdrant
AUTH_PROVIDER=local
DB_PROVIDER=sqlite
EVENT_PROVIDER=websocket
SEARCH_PROVIDER=disabled
ENABLE_DIARIZATION=false

# Ollama LLM (used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b       # default model — used when a purpose-specific var is not set
# OLLAMA_CHAT_MODEL=          # conversational chat + streaming (falls back to OLLAMA_MODEL)
# OLLAMA_EXTRACT_MODEL=       # generate / action-item extraction (falls back to OLLAMA_MODEL)
# OLLAMA_TIMEOUT=300

# Qdrant vector DB (used when VECTOR_DB_PROVIDER=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Local embeddings (used when EMBEDDINGS_PROVIDER=local)
LOCAL_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_EMBEDDINGS_DIM=384

# Local STT via faster-whisper (used when STT_PROVIDER=local)
LOCAL_WHISPER_MODEL=base
# LOCAL_WHISPER_DEVICE=cpu
# LOCAL_WHISPER_COMPUTE_TYPE=int8

# macOS: ctranslate2 and PyTorch each bundle OpenMP; this prevents an abort on load.
KMP_DUPLICATE_LIB_OK=TRUE

# LAN IP of this machine — needed when other devices (mobile, desktop app on a
# different machine) connect over the local network. Leave as localhost when all
# components run on the same machine.
LOCAL_MACHINE_HOST=localhost

# SQLite database path (used when DB_PROVIDER=sqlite)
SQLITE_PATH=./omi_local.db

# Local JWT auth (used when AUTH_PROVIDER=local)
LOCAL_JWT_SECRET=change-me-in-production
LOCAL_JWT_TTL_SECONDS=86400     # 24 hours — increase if desktop app sessions expire too soon

# Admin account bootstrapped on first startup
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Optional: protect /docs, /redoc, and /openapi.json behind a key.
# Leave blank (default) to keep Swagger UI publicly accessible — fine on a trusted LAN.
# When set, access via: http://localhost:8088/docs?key=<DOCS_API_KEY>
DOCS_API_KEY=

# iOS app compatibility: accept Firebase ID tokens without contacting Firebase.
# When enabled, any Bearer token is accepted — restrict to trusted LAN only.
# Required if using the iOS app for auth (iOS sign in via Firebase, backend accepts the token).
# Disable (or leave unset) when using the Desktop app or pin_bridge exclusively.
# LOCAL_AUTH_BYPASS=true
