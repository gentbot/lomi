# =====================================================================
# ──── LOCAL MODE EXAMPLE CONFIGURATION ─────────────────────────────────
# Copy this file to .env for a fully local setup (zero cloud dependencies)
# Requires: Ollama running + Qdrant in Docker (see SETUP_FROM_SCRATCH.md)
# =====================================================================

# ──── LOCAL PROVIDER SELECTION ───────────────────────────────────────
LLM_PROVIDER=ollama
STT_PROVIDER=local
EMBEDDINGS_PROVIDER=local
VECTOR_DB_PROVIDER=qdrant
AUTH_PROVIDER=local
DB_PROVIDER=sqlite
EVENT_PROVIDER=websocket
SEARCH_PROVIDER=disabled
ENABLE_DIARIZATION=false

# ──── OLLAMA CONFIGURATION ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b
OLLAMA_TIMEOUT=300

# ──── QDRANT CONFIGURATION ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ──── LOCAL EMBEDDINGS CONFIGURATION ─────────────────────────────────
LOCAL_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_EMBEDDINGS_DIM=384

# ──── LOCAL WHISPER CONFIGURATION ─────────────────────────────────────
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8

# ──── SQLITE CONFIGURATION ────────────────────────────────────────────
SQLITE_PATH=./omi_local.db

# ──── LOCAL AUTH ──────────────────────────────────────────────────────
# IMPORTANT: Change LOCAL_JWT_SECRET before first boot.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
LOCAL_JWT_SECRET=change-me-in-production
LOCAL_JWT_TTL_SECONDS=86400
# LOCAL_AUTH_BYPASS=true
# Uncomment only if using the iOS app (accepts Firebase tokens without contacting Firebase).
# Only enable on a trusted private LAN — any Bearer token is accepted when set.

# ──── BOOTSTRAP ADMIN (optional) ─────────────────────────────────────
# Comment out these lines if you want to create admin users via /auth/register instead
# BOOTSTRAP_ADMIN_EMAIL=admin@omi.dev
# BOOTSTRAP_ADMIN_PASSWORD=changeme

# ──── ENCRYPTION ─────────────────────────────────────────────────────
# IMPORTANT: Change this to a unique random value — anyone with this value can decrypt stored data.
# Generate: python3 -c "import secrets; print('omi_' + secrets.token_urlsafe(48))"
ENCRYPTION_SECRET='omi_ZwB2ZNqB2HHpMK6wStk7sTpavJiPTFg7gXUHnc4tFABPU6pZ2c2DKgehtfgi4RZv'

# ──── CLOUD PROVIDERS (empty for local mode) ───────────────────────────
# Leave these empty when running in local mode
GOOGLE_APPLICATION_CREDENTIALS=
PINECONE_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
FIREBASE_API_KEY=
HUME_API_KEY=
RAPID_API_KEY=
STRIPE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHOOP_CLIENT_ID=
NOTION_CLIENT_ID=
GOOGLE_CLIENT_ID=
TWITTER_CLIENT_ID=
LANGSMITH_API_KEY=
HUGGINGFACE_TOKEN=

# ──── INTEGRATION OAUTH (disabled in local mode) ───────────────────────
GITHUB_TOKEN=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
PERPLEXITY_API_KEY=

# ──── REDIS (optional, local mode doesn't require it) ───────────────────
REDIS_DB_HOST=
REDIS_DB_PORT=
REDIS_DB_PASSWORD=
